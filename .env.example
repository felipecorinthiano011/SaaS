# ============================================================================
# LINKEDIN RESUME OPTIMIZER - Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env with real secrets to version control
# ============================================================================

# DATABASE CONFIGURATION
# =====================
POSTGRES_DB=resume_optimizer
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=resume_password

# BACKEND - JWT AUTHENTICATION
# =============================
# Generate secure key: openssl rand -base64 32
JWT_SECRET=replace_with_a_very_long_dev_secret_key_min_32_chars
JWT_EXPIRATION_SECONDS=3600

# AI SERVICE - OPENAI API (REQUIRED)
# ===================================
# Get your API key from: https://platform.openai.com/api-keys
# This is MANDATORY for the AI analysis features to work
OPENAI_API_KEY=sk-proj-your-api-key-here

# AI SERVICE CONFIGURATION
# =========================
AI_LLM_NAME=gpt-4o-mini
AI_DEBUG=false
AI_MINIMUM_KEYWORD_COUNT=15

# SPRING BOOT CONFIGURATION
# ==========================
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# ============================================================================
# SECURITY REMINDERS FOR PRODUCTION
# ============================================================================
# 1. JWT_SECRET: Generate a secure key with openssl rand -base64 32
# 2. POSTGRES_PASSWORD: Use a strong, unique, randomly generated password
# 3. OPENAI_API_KEY: Keep secret, use AWS Secrets Manager or similar in prod
# 4. Use managed database services (AWS RDS, Google Cloud SQL, etc)
# 5. Enable HTTPS and CORS only for trusted domains
# ============================================================================
