# =============================================================================
# Docker Environment Configuration
# Copy this file to .env and update with your values
# =============================================================================

# DATABASE CONFIGURATION
# =====================
POSTGRES_DB=resume_optimizer
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=resume_password

# BACKEND - JWT CONFIGURATION
# ============================
# Generate secure key: openssl rand -base64 32
JWT_SECRET=replace_with_a_very_long_dev_secret_key_min_32_chars
JWT_EXPIRATION_SECONDS=3600

# BACKEND - DATABASE CONNECTION
# ==============================
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/resume_optimizer
SPRING_DATASOURCE_USERNAME=resume_user
SPRING_DATASOURCE_PASSWORD=resume_password

# BACKEND - AI SERVICE
# ====================
AI_SERVICE_BASE_URL=http://ai-service:8000

# AI SERVICE CONFIGURATION
# ========================
# OpenAI API Key (required for LLM features)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-

# LLM Model Selection
AI_LLM_NAME=gpt-4o-mini

# AI Service Debug Mode
AI_DEBUG=false

# ATS Keywords Minimum Count
AI_MINIMUM_KEYWORD_COUNT=15

# PYTHON CONFIGURATION
# ====================
PYTHONUNBUFFERED=1

# SPRING BOOT CONFIGURATION
# ==========================
SPRING_APPLICATION_NAME=resume-optimizer-backend
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# PORT CONFIGURATION
# ==================
SERVER_PORT=8080
AI_SERVICE_PORT=8000
DATABASE_PORT=5432
FRONTEND_PORT=4200

# =============================================================================
# SECURITY NOTES FOR PRODUCTION:
# =============================================================================
# 1. JWT_SECRET: Generate a secure key in production
#    Command: openssl rand -base64 32
#
# 2. POSTGRES_PASSWORD: Use a strong, unique password
#    Never commit real passwords to version control
#
# 3. OPENAI_API_KEY: Keep secret, use secure environment management
#    Consider using: AWS Secrets Manager, HashiCorp Vault, etc.
#
# 4. Database: Use managed PostgreSQL service in production
#    Examples: AWS RDS, Google Cloud SQL, Azure Database
#
# 5. All default values should be changed before production
# =============================================================================
